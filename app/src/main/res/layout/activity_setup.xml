<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:padding="32dp"
    android:background="#F0F0F5">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#44403C"
        android:layout_marginTop="32dp" />

    <TextView
        android:id="@+id/tv_setup_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="18sp"
        android:textColor="#44403C"
        android:gravity="center"
        android:layout_marginTop="24dp"
        android:lineSpacingMultiplier="1.3" />

    <Button
        android:id="@+id/btn_settings"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/settings_title"
        android:backgroundTint="#44403C"
        android:textColor="#FFFFFF"
        android:visibility="gone" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/setup_guide"
        android:textSize="15sp"
        android:textColor="#44403C"
        android:gravity="center"
        android:layout_marginTop="16dp"
        android:lineSpacingMultiplier="1.3" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="24dp"
        android:baselineAligned="false">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/setup_step_enable_short"
            android:textColor="#44403C"
            android:textSize="15sp" />

        <Button
            android:id="@+id/btn_enable_ime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/setup_enable"
            android:backgroundTint="#44403C"
            android:textColor="#FFFFFF" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="8dp"
        android:baselineAligned="false">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/setup_step_select_short"
            android:textColor="#44403C"
            android:textSize="15sp" />

        <Button
            android:id="@+id/btn_select_ime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/setup_select"
            android:backgroundTint="#44403C"
            android:textColor="#FFFFFF" />
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/setup_step_start_short"
        android:textColor="#44403C"
        android:textSize="15sp"
        android:gravity="center"
        android:layout_marginTop="8dp" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="16dp">

        <Button
            android:id="@+id/btn_input_test"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/setup_input_test"
            android:backgroundTint="#44403C"
            android:textColor="#FFFFFF" />
    </LinearLayout>

</LinearLayout>